---

## `loader.luau`

```lua
--[[
    SQL - Universal Loader
    Loads all modules from GitHub in the correct order.
]]

local BASE_URL = "https://raw.githubusercontent.com/yourusername/SQL/main/"

local modules = {
    "sql_main.luau",
    "sql_select.luau",
    "sql_add.luau",
    "sql_remove.luau",
    "sql_inject.luau",
    "sql_backdoor.luau"
}

for _, moduleName in ipairs(modules) do
    local url = BASE_URL .. moduleName
    local success, result = pcall(function()
        return game:HttpGet(url)
    end)

    if success and result then
        loadstring(result)()
        print("[Loader] Loaded: " .. moduleName)
    else
        warn("[Loader] Failed to load: " .. moduleName)
    end
end

print("[SQL] All modules loaded. Use getgenv().SQL to access.")
